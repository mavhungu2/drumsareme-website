{
  "hosting": {
    "public": "out",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      { "source": "/api/checkout", "function": "createCheckout" },
      { "source": "/api/yoco/webhook", "function": "yocoWebhook" },
      { "source": "/api/admin/admins", "function": "adminUsers" },
      { "source": "/api/admin/admins/**", "function": "adminUsers" },
      { "source": "/api/admin/orders", "function": "adminListOrders" },
      { "source": "/api/admin/orders/**", "function": "adminOrderActions" },
      { "source": "/api/orders/**", "function": "getOrder" }
    ],
    "headers": [
      {
        "source": "/_next/static/**",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=31536000, immutable"
          }
        ]
      }
    ]
  },
  "functions": {
    "source": "functions",
    "runtime": "nodejs20",
    "predeploy": ["npm --prefix \"$RESOURCE_DIR\" run build"]
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  }
}
